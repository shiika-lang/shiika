class Main
  def self.run()
    # Sum of i*j where i in [1,2] and j in [2,3]
    # = 1*2 + 1*3 + 2*2 + 2*3 = 2 + 3 + 4 + 6 = 15
    var sum = 0
    var i = 1
    while i < 3
      var j = 2
      while j < 4
        sum += i * j
        sleep_sec 0
        j += 1
      end
      i += 1
    end
    unless sum == 15
      puts "ng: while_while"
    end
  end
end

Main.run
puts "ok"
