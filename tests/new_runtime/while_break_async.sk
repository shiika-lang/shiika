class Main
  def self.foo(log: Array<Int>) -> Int
    var i = 0
    while i < 10
      sleep_sec 0
      if i == 3
        break
      end
      log.push(i)
      i += 1
    end
    return i
  end

  def self.run()
    let log = Array<Int>.new
    let last = foo(log)
    # Expected: log=[0, 1, 2] and last == 3 (break at i==3 preserves i)
    unless (log[0] == 0 and log[1] == 1 and log[2] == 2 and log.length == 3 and last == 3)
      puts "ng: while_break_async"
    end
  end
end

Main.run
puts "ok"
